generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  password  String
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id              String           @id @default(cuid())
  name            String
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  structureType   StructureType
  status          ProjectStatus    @default(DRAFT)
  answers         Json             @default("{}")
  summary         Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  bidInvitations  BidInvitation[]
  versions        ProjectVersion[]
  blueprintOrders BlueprintOrder[]
}

enum BlueprintOrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  COMPLETE
  FAILED
}

model BlueprintOrder {
  id                String               @id @default(cuid())
  projectId         String
  project           Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status            BlueprintOrderStatus @default(PENDING_PAYMENT)
  tier              String               @default("spec")
  architecturalData Json                 @default("{}")
  files             Json                 @default("[]")
  stripeSessionId   String?              @unique
  externalOrderId   String?
  paidAt            DateTime?
  submittedAt       DateTime?
  completedAt       DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model ProjectVersion {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version   Int
  name      String
  answers   Json
  createdAt DateTime @default(now())
}

model BidInvitation {
  id                String    @id @default(cuid())
  token             String    @unique @default(cuid())
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tradeName         String
  tradeDescription  String
  tradeCategory     String
  budgetLow         Float     @default(0)
  budgetHigh        Float     @default(0)
  licenseNote       String    @default("")
  contractorEmail   String
  contractorName    String?
  // Submitted bid data
  bidAmount         Float?
  durationWeeks     Int?
  startDate         String?
  companyName       String?
  licenseNumber     String?
  insuranceInfo     String?
  materialsIncluded String?
  exclusions        String?
  notes             String?
  submittedAt       DateTime?
  createdAt         DateTime  @default(now())
}

enum StructureType {
  SINGLE_FAMILY_HOME
  CONTAINER_HOME
  BARNDOMINIUM
  BARN
  LOG_CABIN
  A_FRAME
  SHED
  WORKSHOP
  GARAGE
  TINY_HOME
  DOME_HOME
  QUONSET_HUT
  SILO
  POLE_BARN
  EARTHSHIP
  PASSIVE_SOLAR
}

enum ProjectStatus {
  DRAFT
  IN_PROGRESS
  COMPLETE
}
